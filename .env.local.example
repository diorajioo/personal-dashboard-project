# ─── Auth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-run-openssl-rand-base64-32

# ─── Google (Sheets + Calendar) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SHEETS_ID=           # The ID from your GSheet URL

# ─── Microsoft (Outlook + Calendar) ─────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ─── Spotify ─────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Notion ──────────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_ID=         # Tasks database ID

# ─── Twelve Data (Stocks - free tier: 800 calls/day) ─────
TWELVE_DATA_API_KEY=

# ─── News RSS (no key needed, uses public RSS feeds) ─────
# Feedly / direct RSS — no key required

# ─── Groq AI (free tier) ─────────────────────────────────
GROQ_API_KEY=

# ─── Weather (Open-Meteo - completely free, no key) ──────
# No key needed!
